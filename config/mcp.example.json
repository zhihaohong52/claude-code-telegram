{
  "mcpServers": {
    "telegram": {
      "command": "python",
      "args": ["src/mcp/telegram_server.py"]
    },
    "google-maps": {
      "command": "bunx",
      "args": ["-y", "@cablate/mcp-google-map", "--stdio"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "your_google_maps_api_key_here",
        "GOOGLE_MAPS_ENABLED_TOOLS": "maps_geocode,maps_reverse_geocode,maps_directions,maps_distance_matrix,maps_search_places,maps_search_nearby,maps_place_details,maps_static_map"
      }
    },
    "sg-public-transport": {
      "command": "bunx",
      "args": ["-y", "@siva-sub/mcp-public-transport"],
      "env": {
        "LTA_ACCOUNT_KEY": "your_lta_account_key_here",
        "ONEMAP_EMAIL": "your_onemap_email@example.com",
        "ONEMAP_PASSWORD": "your_onemap_password_here"
      }
    },
    "mrt-exits": {
      "command": "poetry",
      "args": ["run", "python", "src/mcp/mrt_exits_server.py"]
    }
  }
}
